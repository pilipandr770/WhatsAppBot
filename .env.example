# ─── Database ────────────────────────────────────────
# For Docker Compose (local dev):
POSTGRES_DB=whatsapp_saas
POSTGRES_USER=wauser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# For Render / shared PostgreSQL: set full URL + optional schema
DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SCHEMA=whatsapp_saas   # optional: isolates tables in their own schema

# ─── App ─────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
APP_BASE_URL=https://yourdomain.onrender.com

# ─── Evolution API ────────────────────────────────────
EVOLUTION_API_URL=https://evolution-api.onrender.com
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_KEY

# ─── Anthropic ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard as recurring monthly
STRIPE_PRICE_SOLO=price_...      # Solo-Assistent  €59/Monat  1 Nummer
STRIPE_PRICE_BUSINESS=price_...  # Business        €149/Monat 3 Nummern
STRIPE_PRICE_AGENTUR=price_...   # Agentur         €349/Monat 15 Nummern

# ─── Storage ─────────────────────────────────────────
UPLOAD_FOLDER=/app/uploads
